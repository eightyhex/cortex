# Cortex project-specific
# =============================================================================

# User configuration (copy settings.example.yaml → settings.yaml and customize)
settings.yaml

# Derived data — all rebuildable from the vault, never commit
data/

# The user's actual Obsidian vault (separate from vault.example/)
/vault/

# Downloaded embedding models
.cache/
.huggingface/
models/

# Draft notes pending approval
data/drafts/

# DuckDB write-ahead log
*.duckdb-shm
*.duckdb-wal

# Eval snapshots with real data (committed manually when stable)
evals/snapshots/*.json
!evals/snapshots/.gitkeep

